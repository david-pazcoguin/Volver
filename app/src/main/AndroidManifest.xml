<?xml version="1.0" encoding="utf-8"?> <!--This file is using utf-8 -->
    <!-- Everything contained within the manifest is what android will be expected for the app-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- extensible markup language namespace, the link is the id string for the name space-->
    <!-- this is to get the prefix "android that will be used below-->
    <!-- and package is the app unique id, so for this app, com.wheic.arapp is this apps unique id-->

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- this tells android that this app will use camera and will request permission-->
    <!-- same for internet-->
    <!-- same for checking general area e.g. city-->
    <!-- same for checking precise area 50m rad-->
    <!-- same for checking if internet is present or absent-->

    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />
    <!-- this tells android that this app requires this feature (software or hardware)-->
    <!-- it requires OpenGL ES 3.0, and that it is strictly required -->
    <!-- this helps playstore know which devices are capable of downloading this app -->
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="true" />
    <!-- same for requiring a camera with ar core capabilities. this is different from just requiring a camera -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <!-- same for requiring a camera which is already understood when requiring ar camera, but is kept for metadata  -->
    <uses-feature android:name="android.hardware.location.gps" />
    <!-- same for requiring a device that can use gps -->

    <application
        android:allowBackup="true"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.ARApp"
        android:usesCleartextTraffic="true">
        <!-- allows android to back up some of the users data -->
        <!-- use what logo on square and round icons found in res/drawable/logo.png -->
        <!-- supports languages and styles that reads or starts from left to right like hebrew etc -->
        <!-- uses the theme style that can be found in res/values/themes  -->
        <!-- and uses http instead of the encrypted https for simplicity-->

        <activity
            android:name=".AboutUsActivity"
            android:exported="false" />
        <!-- each activity is a page, and exported as false means you want to open this through your app only -->
        <!-- no other app or software can directly lead you to this page-->
        <activity
            android:name=".AccountSettingActivity"
            android:exported="false" />
        <activity
            android:name=".SettingActivity"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".HomeActivity"
            android:exported="false" />
        <activity
            android:name=".ARActivity"
            android:exported="false" />
        <activity
            android:name=".WalletSetupActivity"
            android:exported="false" />
        <activity
            android:name=".NFTClaimActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <!-- this is exported as true because this is the entry point of our app -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- this tells android that this is the page that should open when the app is launched-->
            <!-- intent filters tells what actions it can do -->
            <!-- android.intent.action.MAIN tells android that this is the main entrypoint of this app -->
            <!-- android.intent.category.LAUNCHER tells android to show this activity as an icon in a launcher -->
            <!-- android puts an icon on it and puts it in the homescreen for users to tap open-->
        </activity>

        <meta-data
            android:name="com.google.ar.core"
            android:value="required" />
        <meta-data
            android:name="com.google.ar.core.min_apk_version"
            android:value="191561055" />
        <!-- meta data is a way to show short info, so this meta data this tells ARCore / Google Play
        that this app REQUIRES AR support and devices without ARCore should not be allowed to install/run it. -->
    </application>

</manifest>