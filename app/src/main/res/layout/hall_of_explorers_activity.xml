<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/hero_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/linearLayoutBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/back_icon"
                app:tint="@color/gold_hero" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="BACK"
                android:textColor="@color/gold_hero"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:text="Hall of Explorers"
                android:textColor="@color/gold_hero"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/cabin"
                android:text="Recognizing explorers who completed Volver Al Pasado missions across Intramuros."
                android:textColor="@color/gold_pale"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/cardLeaderboardSpotlight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_leaderboard_spotlight"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="III"
                    android:textColor="@color/gold_hero"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSpotlightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0.08"
                        android:text="LEADERBOARD"
                        android:textColor="@color/gold_bright"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSpotlightTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Overall Crown"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSpotlightBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/cabin"
                        android:text="Fastest clears rise to the top. Switch boards to compare each mission's best runs."
                        android:textColor="@color/gold_hero"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupModes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOverall"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Overall" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMissionRankings"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mission Rankings" />
            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupMissionBoards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFortSantiago"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Fort Santiago" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBaluarte"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Baluarte" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCasaManila"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Casa Manila" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMuseo"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Museo" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCentro"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Centro" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSanAgustin"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="San Agustin" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipManilaCathedral"
                    style="@style/Widget.ARApp.LeaderboardChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cathedral" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/tvCachedBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_stat_card"
                android:fontFamily="@font/cabin"
                android:padding="12dp"
                android:text="Showing last synced rankings"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressHall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutHiddenNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="You are hidden from public rankings."
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/cabin"
                    android:text="Update your visibility in Profile if you want to appear in the Hall of Explorers."
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnManageVisibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_continue_button"
                    android:fontFamily="@font/montserrat_bold"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="Manage Visibility"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCurrentUserCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvCurrentUserRank"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="#12"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCurrentUserAvatar"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/circle_primary_bg"
                    android:fontFamily="@font/montserrat_bold"
                    android:gravity="center"
                    android:text="Y"
                    android:textColor="@color/gold_hero"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCurrentUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Your Rank"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentUserDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/cabin"
                        android:text="3 of 7 missions complete"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCurrentUserSouvenir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_continue_button"
                    android:fontFamily="@font/montserrat_bold"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Souvenir Minted"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_home_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="No explorers yet"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmptyBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/cabin"
                    android:gravity="center"
                    android:text="No verified completions have been recorded for this ranking yet."
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_home_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Could not load rankings"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/cabin"
                    android:gravity="center"
                    android:text="Please check your internet connection and try again."
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_continue_button"
                    android:fontFamily="@font/montserrat_bold"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="Retry"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRankings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        app:itemIconTint="@color/nav_icon_tint"
        app:itemTextColor="@color/nav_icon_tint"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
