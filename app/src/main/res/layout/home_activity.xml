<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".HomeActivity">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgDashboard"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/dashboard_icon"
            android:contentDescription="Open dashboard"
            android:layout_marginStart="15dp"
            android:layout_gravity="center"
            android:layout_width="32dp"
            android:layout_height="32dp">

        </ImageView>

        <LinearLayout
            android:layout_margin="15dp"
            android:layout_weight="3"
            android:layout_marginEnd="15sp"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvFullName"
                android:fontFamily="@font/montserrat_bold"
                android:textSize="15sp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:text="Hello User!"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

            </TextView>

            <TextView
                android:fontFamily="@font/montserrat_regular"
                android:textSize="15sp"
                android:textAlignment="center"
                android:textColor="@color/silver"
                android:textStyle="bold"
                android:text="Welcome to Volver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

            </TextView>

        </LinearLayout>

    </LinearLayout>
    <View
        android:background="@color/silver"
        android:layout_width="match_parent"
        android:layout_height="1dp">

    </View>

    <!-- Mission progress counter -->
    <TextView
        android:id="@+id/tvProgressLabel"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="10dp"
        android:textSize="13sp"
        android:textColor="#888888"
        android:fontFamily="@font/montserrat_regular"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Treasure chest reward (shown only when all missions complete) -->
    <LinearLayout
        android:id="@+id/treasureChestContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Treasure chest — tap to claim NFT">

        <ImageView
            android:id="@+id/imgTreasureChest"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/treasure_chest_closed" />

        <TextView
            android:id="@+id/tvTreasureCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="A treasure has appeared…"
            android:textColor="#8B4513"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat_bold" />

        <TextView
            android:id="@+id/tvTreasureHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to open"
            android:textColor="#AA7B3C"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat_regular" />
    </LinearLayout>

    <!-- Legacy NFT claim card — retained for backward compat, kept hidden -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardNFTClaim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvNFTClaimStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_margin="15dp"
        android:fontFamily="@font/montserrat_bold"
        android:textSize="22sp"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:text="Mission(s)"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

    </TextView>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>