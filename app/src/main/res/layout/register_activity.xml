<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_page"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Heritage header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/hero_bg">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginLeft="16dp"
                android:padding="8dp"
                android:src="@drawable/back_icon"
                android:tint="@color/gold_hero"
                android:contentDescription="Back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/montserrat_bold"
                android:text="Create Account"
                android:textColor="@color/gold_hero"
                android:textSize="20sp" />
        </FrameLayout>

        <!-- Form card -->
        <androidx.cardview.widget.CardView
            app:cardElevation="12dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/bg_card"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="-20dp"
            android:layout_marginBottom="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:fontFamily="@font/cabin"
                    android:text="Fill in your details to get started"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint_color"
                    android:layout_marginBottom="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <!-- First Name -->
                <TextView
                    android:fontFamily="@font/montserrat_bold"
                    android:text="First Name"
                    android:textSize="12sp"
                    android:textColor="@color/wet_asp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundColor="@color/bg_field"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cabin"
                        android:hint="Enter your first name"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Last Name -->
                <TextView
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Last Name"
                    android:textSize="12sp"
                    android:textColor="@color/wet_asp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundColor="@color/bg_field"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtLastName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cabin"
                        android:hint="Enter your last name"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email -->
                <TextView
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Email"
                    android:textSize="12sp"
                    android:textColor="@color/wet_asp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundColor="@color/bg_field"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cabin"
                        android:hint="Enter your email address"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Username -->
                <TextView
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Username"
                    android:textSize="12sp"
                    android:textColor="@color/wet_asp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundColor="@color/bg_field"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cabin"
                        android:hint="Choose a username (letters, numbers, _)"
                        android:inputType="text"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <TextView
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Password"
                    android:textSize="12sp"
                    android:textColor="@color/wet_asp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundColor="@color/bg_field"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cabin"
                        android:hint="At least 6 characters"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Confirm Password -->
                <TextView
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Confirm Password"
                    android:textSize="12sp"
                    android:textColor="@color/wet_asp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxBackgroundColor="@color/bg_field"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cabin"
                        android:hint="Re-enter your password"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Register button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/hero_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingTop="15dp"
                        android:paddingBottom="15dp"
                        android:text="CREATE ACCOUNT"
                        android:textColor="@color/gold_hero"
                        android:textSize="15sp" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:fontFamily="@font/cabin"
                android:text="Already have an account?"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvLogin"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/montserrat_bold"
                android:text=" LOG IN"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>