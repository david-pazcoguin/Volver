<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed: bright warm gold flash -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFD740" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Selected (compass open): deep amber-orange, clearly "on" -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF8F00" />
            <stroke android:width="2dp" android:color="#FFCC02" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Default: dark ghost button with amber outline -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
            <stroke android:width="1.5dp" android:color="#FFC107" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
