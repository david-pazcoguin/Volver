<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Deny cleartext (HTTP) traffic globally.
         All connections must use HTTPS / TLS. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Certificate pinning for the Polygon RPC endpoint.
         TODO: Replace PLACEHOLDER_PIN_HASH with the real SHA-256 pin obtained by running:
         openssl s_client -connect rpc-amoy.polygon.technology:443 \
           | openssl x509 -pubkey -noout \
           | openssl pkey -pubin -outform der \
           | openssl dgst -sha256 -binary \
           | openssl enc -base64
         Add a second <pin> element with a backup pin (e.g. an intermediate CA key)
         so the app keeps working if the leaf certificate rotates. -->
    <!-- Amoy testnet RPC -->
    <domain-config>
        <domain includeSubdomains="true">rpc-amoy.polygon.technology</domain>
        <pin-set expiration="2027-01-01">
            <pin digest="SHA-256">u1OlCFGpiDPSm7IclXp18QMJNfQzxWJb04KcCYSHjOg=</pin>
            <!-- Backup pin (GlobalSign Root R3 — intermediate CA) -->
            <pin digest="SHA-256">cGuxAXyFXFkWm61cF4HPWX8S0srS9j0aSqN0k4AP+4A=</pin>
        </pin-set>
    </domain-config>

    <!-- Polygon mainnet RPC (for production) -->
    <domain-config>
        <domain includeSubdomains="true">polygon-rpc.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- Replace with actual mainnet pin before production launch -->
            <pin digest="SHA-256">cGuxAXyFXFkWm61cF4HPWX8S0srS9j0aSqN0k4AP+4A=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
