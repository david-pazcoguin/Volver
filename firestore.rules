rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profile document rules.
    // Every user can only access the document whose ID matches their auth UID.
    match /users/{uid} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      allow create: if request.auth != null
                    && request.auth.uid == uid;

      // Allow updates only for the owner and only for mutable profile/progress fields.
      // This blocks clients from writing protected/system-managed fields.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasOnly([
                        'username',
                        'firstName',
                        'lastName',
                        'walletAddress',
                        'allComplete',
                        'whitelisted',
                        'whitelistedAt',
                        'email',
                        'createdAt'
                       ]);

      // Never allow profile deletes from clients.
      allow delete: if false;

      // Mission completion records for each user.
      match /missions/{missionId} {
        // Users can only read their own mission records.
        allow read: if request.auth != null
                    && request.auth.uid == uid;

        // Mission records are append-only and only valid when marked completed.
        // Requires missionId field to be a string for predictable schema.
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.completed == true
                      && request.resource.data.missionId is string;

        // Missions cannot be edited or removed once written.
        allow update: if false;
        allow delete: if false;
      }
    }

    // Deny all access outside explicitly allowed paths above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
