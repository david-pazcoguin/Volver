rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profile document rules.
    // Every user can only access the document whose ID matches their auth UID.
    match /users/{uid} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // Create: require all expected fields and validate types.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.username is string
                    && request.resource.data.firstName is string
                    && request.resource.data.lastName is string
                    && request.resource.data.email is string
                    && request.resource.data.username.size() >= 3
                    && request.resource.data.username.size() <= 30;

      // Allow updates only for the owner and only for mutable profile/progress fields.
      // email and createdAt are immutable — they can only be set during create.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['username', 'firstName', 'lastName',
                                 'walletAddress', 'allComplete',
                                 'whitelisted', 'whitelistedAt']);

      // Never allow profile deletes from clients.
      allow delete: if false;

      // Mission completion records for each user.
      match /missions/{missionId} {
        // Users can only read their own mission records.
        allow read: if request.auth != null
                    && request.auth.uid == uid;

        // Mission records are append-only and only valid when marked completed.
        // missionId must match the document ID and be one of the 5 known landmarks.
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.completed == true
                      && request.resource.data.missionId is string
                      && request.resource.data.missionId == missionId
                      && request.resource.data.missionId in [
                           'fort_santiago',
                           'baluarte_san_diego',
                           'casa_manila',
                           'museo_intramuros',
                           'centro_turismo'
                         ]
                      && request.resource.data.completedAt is timestamp;

        // Missions cannot be edited or removed once written.
        allow update: if false;
        allow delete: if false;
      }
    }

    // Deny all access outside explicitly allowed paths above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
